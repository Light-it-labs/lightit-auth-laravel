<?php

declare(strict_types=1);

namespace Lightit\Authentication\App\Controllers;

use Illuminate\Http\Response;
use Lightit\Authentication\App\Requests\OtpSendRequest;
use Lightit\Authentication\Domain\Actions\SendOtpAction;

final readonly class OtpSendController
{
    public function __invoke(OtpSendRequest $request, SendOtpAction $sendOtpAction): Response
    {
        $sendOtpAction->execute($request->toDto());

        return response()->noContent();
    }
}
