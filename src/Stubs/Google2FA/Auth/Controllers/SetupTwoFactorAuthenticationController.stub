<?php

declare(strict_types=1);

namespace Lightit\Authentication\App\Controllers;

use Illuminate\Http\JsonResponse;
use Lightit\Authentication\App\Requests\SetupTwoFactorAuthenticationRequest;
use Lightit\Authentication\App\Resources\TwoFactorAuthenticationSetUpResource;
use Lightit\Authentication\Domain\Actions\SetupTwoFactorAuthenticationAction;

final readonly class SetupTwoFactorAuthenticationController
{
    public function __invoke(
        SetupTwoFactorAuthenticationRequest $request,
        SetupTwoFactorAuthenticationAction $setupTwoFactorAuthenticationAction,
    ): JsonResponse {
        $setupData = $setupTwoFactorAuthenticationAction->execute($request->get2faUser());

        return TwoFactorAuthenticationSetUpResource::make($setupData)
            ->response();
    }
}
